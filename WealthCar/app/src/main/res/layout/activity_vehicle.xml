<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3E8E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastre seu veículo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#150f8c"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Para começar a monitorar, precisamos de algumas informações."
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp"/>

        <!-- Apelido -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Apelido do veículo (opcional)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVehicleApelido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Marca -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marca *"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp"/>

        <!-- Spinner Marca -->
        <Spinner
            android:id="@+id/spinnerMarca"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <!-- Label Modelo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modelo *"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp"/>

        <!-- Spinner Modelo -->
        <Spinner
            android:id="@+id/spinnerModelo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <!-- Ano -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ano *"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVehicleAno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="4"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Placa -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Placa * (somente letras maiúsculas e números)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVehiclePlaca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:maxLength="8"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Quilometragem -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quilometragem atual (km)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etVehicleQuilometragem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Combustível -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Combustível"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp"/>

        <!-- Spinner Combustível -->
        <Spinner
            android:id="@+id/spinnerCombustivel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <!-- Botão salvar -->
        <Button
            android:id="@+id/btnSalvarVeiculo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ir para o Dashboard"
            android:backgroundTint="#150f8c"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>